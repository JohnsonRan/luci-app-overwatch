config overwatch 'global'
	option enabled '1'
	option sample_interval '2'
	option retention_hours_min '48'
	option retention_days_hour '35'
	option retention_days_day '395'
	option db_path '/etc/overwatch/overwatch.db'
	option dns_stats_enabled '0'
	option dns_iface 'br-lan'
	option dns_flush_secs '60'
	option dns_top_n '50'
	list lan_prefix '192.168.1.0/24'
