#!/bin/sh /etc/rc.common
# overwatchd — per-client traffic monitor

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/overwatchd

start_service() {
	mkdir -p /etc/overwatch

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "overwatch"
}
